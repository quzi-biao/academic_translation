# ----------------------------------------
# 闻一翻译 / academic_translation
# 本地开发环境变量示例
# 复制为 server/.env 后按需修改
# ----------------------------------------

# 基础服务
NODE_ENV=development
PORT=7000
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/academic_translation?schema=public"
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# 对象存储（必填：上传文档、图片和导出依赖 OSS）
OSS_ENDPOINT="oss-cn-hangzhou.aliyuncs.com"
OSS_KEY_ID="your-oss-key-id"
OSS_KEY_SECRET="your-oss-key-secret"
OSS_BUCKET="your-oss-bucket"
OSS_FOLDER="academic_translation-dev"

# 翻译大模型（必填：总结 / prompt / 翻译依赖）
LLM_BASE_URL="https://your-llm-provider.example/v1"
LLM_API_KEY="your-llm-api-key"
LLM_MODEL="gemini-2.5-flash"

# 文档解析（必填）
# MINERU_BIN: magic-pdf 可执行文件路径
# CHROME_BIN: Chromium / Chrome 路径，用于 PDF 导出
MINERU_BIN="/absolute/path/to/magic-pdf"
CHROME_BIN="/absolute/path/to/chromium"

# 微信支付（可选：不配置则无法本地测试充值）
WX_APPID="your-wechat-appid"
WX_MCHID="your-wechat-mchid"
WX_PUBLIC_KEY_ID="your-wechat-public-key-id"
WX_SERIAL_NO="your-wechat-serial-no"
WX_PRIVATE_KEY_PATH="/absolute/path/to/apiclient_key.pem"
WX_PUBLIC_KEY_PATH="/absolute/path/to/pub_key.pem"
WX_NOTIFY_URL="https://your-public-domain.example/api/payment/notify"
WX_API_V3_KEY="your-wechat-api-v3-key"

# 可选：如果你复用仓库中保留的部分 AI / 图像 / TTS 能力，可继续配置以下变量
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_BASE="https://generativelanguage.googleapis.com/v1beta"
GPTIMAGE_BASE_URL="https://yunwu.ai"
GPTIMAGE_API_KEY="your-gptimage-api-key"
IMAGE_PROVIDER="gptimage"
MINIMAX_API_KEY="your-minimax-api-key"
WX_MINI_APPID="your-miniapp-appid"
WX_MINI_SECRET="your-miniapp-secret"
